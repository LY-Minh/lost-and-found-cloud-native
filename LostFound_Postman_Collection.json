          }
        ],
        "url": "{{BASE_URL}}/student/submit-claim",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemId\": \"{{ITEM_ID}}\",\n  \"message\": \"This is my game! I prefer physical copies for long-term preservation and must have dropped it while studying.\"\n}"
        }
      }
    },
    {
      "name": "10. Submit Feedback (Student)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
