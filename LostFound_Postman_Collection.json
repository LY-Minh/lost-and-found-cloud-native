{
  "info": {
    "name": "Lost & Found API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://35.175.197.76"
    },
    {
      "key": "STUDENT_TOKEN",
      "value": ""
    },
    {
      "key": "ADMIN_TOKEN",
      "value": ""
    },
    {
      "key": "ITEM_ID",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Register Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{BASE_URL}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Vireak Student\",\n  \"email\": \"vireak.dev@student.edu.kh\",\n  \"password\": \"backend_pass456\",\n  \"role\": \"student\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('STUDENT_TOKEN', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Register Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{BASE_URL}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Chanda Admin\",\n  \"email\": \"chanda.admin@university.edu.kh\",\n  \"password\": \"backend_pass456\",\n  \"role\": \"admin\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('ADMIN_TOKEN', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Login Student",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{BASE_URL}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"vireak.dev@student.edu.kh\",\n  \"password\": \"backend_pass456\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('STUDENT_TOKEN', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{BASE_URL}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"chanda.admin@university.edu.kh\",\n  \"password\": \"backend_pass456\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('ADMIN_TOKEN', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Create Item (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{ADMIN_TOKEN}}"
          }
        ],
        "url": "{{BASE_URL}}/admin/items",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Physical Copy of Xenoblade Chronicles 3\",\n  \"description\": \"Found a physical JRPG game cartridge without the box, left near the university library computer area.\",\n  \"category\": \"entertainment\",\n  \"status\": \"found\",\n  \"location\": \"Library Computer Area\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.item && json.item._id) { pm.collectionVariables.set('ITEM_ID', json.item._id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Get All Items",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{STUDENT_TOKEN}}"
          }
        ],
        "url": "{{BASE_URL}}/items"
      }
    },
    {
      "name": "7. Get My Profile (Student)",
      "request": {
        "method": "GET",
        "header": [
