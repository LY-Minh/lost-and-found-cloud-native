{
  "info": {
    "name": "Lost & Found \u2014 K8s Ingress (fanout + gateway auth)",
    "description": "Tests EVERY endpoint through the Ingress single-domain fanout.\n\nSETUP:\n1. ./deploy-minikube.sh (cluster up, images pulled)\n2. /etc/hosts:  <minikube ip>  lostfound.com\n3. Run folders top-to-bottom (or use the Collection Runner) \u2014 tokens and IDs (ITEM_ID, CLAIM_ID) are captured automatically by test scripts.\n\nRequest flow: client -> ingress-nginx -> (auth-url subrequest -> api-gateway /auth-check verifies JWT + role by 2nd path segment) -> service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://lostfound.com",
      "description": "Ingress host (must be in /etc/hosts -> minikube ip)"
    },
    {
      "key": "STUDENT_TOKEN",
      "value": ""
    },
    {
      "key": "ADMIN_TOKEN",
      "value": ""
    },
    {
      "key": "ITEM_ID",
      "value": ""
    },
    {
      "key": "CLAIM_ID",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Auth (public \u2014 no token needed)",
      "description": "Only /auth/login and /auth/register bypass the gateway check (public Ingress object).",
      "item": [
        {
          "name": "1.1 Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Public route. Re-runs return 400 (email exists) \u2014 that's fine, login below refreshes the token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Vireak Student\",\n  \"email\": \"vireak.dev@student.edu.kh\",\n  \"password\": \"backend_pass456\",\n  \"role\": \"student\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 created OR 400 already exists', () => pm.expect([201,400]).to.include(pm.response.code));",
                  "const j = pm.response.json();",
                  "if (j.token) pm.collectionVariables.set('STUDENT_TOKEN', j.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "register"
