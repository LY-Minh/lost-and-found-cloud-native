            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chanda Admin\",\n  \"email\": \"chanda.admin@university.edu.kh\",\n  \"password\": \"backend_pass456\",\n  \"role\": \"admin\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 created OR 400 already exists', () => pm.expect([201,400]).to.include(pm.response.code));",
                  "const j = pm.response.json();",
                  "if (j.token) pm.collectionVariables.set('ADMIN_TOKEN', j.token);"
                ]
              }
            }
          ]
